# MIHAS self-hosted .env TEMPLATE — copy to ~/mihas/.env on the box and fill in.
# Real values are secrets: keep `.env` chmod 600, never commit it.
# Compose builds DATABASE_URL from POSTGRES_* and points it at the local
# postgres container (NOT Neon).

# --- image tags: managed by the deploy workflow; leave as-is on first copy ---
BACKEND_IMAGE=ghcr.io/OWNER/REPO-backend:latest
FRONTEND_IMAGE=ghcr.io/OWNER/REPO-frontend:latest

# --- Caddy edge ---
ADMIN_EMAIL=admin@mihas.edu.zm        # Let's Encrypt account email
APP_HOST=apply.beanola.com
API_HOST=api.beanola.com
JOBS_HOST=jobs.beanola.com

# --- local Postgres (the container) ---
POSTGRES_DB=mihas
POSTGRES_USER=mihas
POSTGRES_PASSWORD=CHANGE_ME_strong_password

# --- Django ---
DJANGO_SETTINGS_MODULE=config.settings.prod
SECRET_KEY=CHANGE_ME
JWT_SIGNING_KEY=CHANGE_ME
AUDIT_LOG_ENCRYPTION_KEY=CHANGE_ME_32+_chars
ALLOWED_HOSTS=api.beanola.com
CORS_ALLOWED_ORIGINS=https://apply.beanola.com,https://api.beanola.com
CSRF_TRUSTED_ORIGINS=https://apply.beanola.com,https://api.beanola.com
APP_VERSION=selfhosted
LOG_LEVEL=INFO

# --- payments (Lenco) ---
LENCO_API_SECRET_KEY=CHANGE_ME
LENCO_PUBLIC_KEY=CHANGE_ME
LENCO_API_BASE_URL=https://api.lenco.co/access/v2/

# --- email (Zoho SMTP primary, Resend fallback) ---
ZOHO_SMTP_HOST=smtp.zoho.com
ZOHO_SMTP_PORT=465
ZOHO_SMTP_USERNAME=CHANGE_ME
ZOHO_SMTP_PASSWORD=CHANGE_ME
ZOHO_FROM_EMAIL=admissions@mihas.edu.zm
RESEND_API_KEY=CHANGE_ME
EMAIL_FROM=admissions@mihas.edu.zm
ERROR_ALERT_EMAIL=admin@mihas.edu.zm

# --- storage (Cloudflare R2 for uploads) ---
S3_ENDPOINT_URL=https://ACCOUNTID.r2.cloudflarestorage.com
S3_BUCKET=mihas-uploads
S3_ACCESS_KEY=CHANGE_ME
S3_SECRET_KEY=CHANGE_ME

# --- error monitoring + AI gateway ---
GLITCHTIP_DSN=CHANGE_ME
AI_GATEWAY_API_KEY=CHANGE_ME
AI_GATEWAY_BASE_URL=https://ai-gateway.vercel.sh/v1

# --- health check target (internal keep-alive/uptime task) ---
HEALTH_CHECK_URL=https://api.beanola.com/health/ready/

# --- nightly DB backup to R2 (used by deploy/backup-db.sh) ---
BACKUP_BUCKET=mihas-backups
BACKUP_RETAIN_DAYS=14

# --- optional Grafana Cloud telemetry (docker-compose.grafana-cloud.yml) ---
# From your Grafana Cloud stack page (Connections → Data sources, or the
# "Send Metrics/Logs" quick-setup). The API key needs the MetricsPublisher +
# LogsPublisher roles. Prometheus and Loki share the API key; usernames differ.
MONITOR_HOSTNAME=mihas-ec2
GCLOUD_API_KEY=
GCLOUD_PROM_URL=https://prometheus-prod-XX-prod-REGION.grafana.net/api/prom/push
GCLOUD_PROM_USER=
GCLOUD_LOKI_URL=https://logs-prod-XXX.grafana.net/loki/api/v1/push
GCLOUD_LOKI_USER=
