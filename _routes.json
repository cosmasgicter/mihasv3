{
  "version": 1,
  "description": "Root routing configuration - delegates to public/_routes.json for specifics",
  "include": [
    "/api/*",
    "/applications",
    "/applications/*",
    "/admin/*",
    "/auth/*",
    "/catalog/*",
    "/cron/*",
    "/debug/*",
    "/documents/*",
    "/generate/*",
    "/interview/*",
    "/mcp/*",
    "/notifications",
    "/notifications/*",
    "/payments/*",
    "/push/*",
    "/send/*",
    "/send-email",
    "/analytics/*",
    "/health",
    "/test-email",
    "/test-auth",
    "/test-live",
    "/test"
  ],
  "exclude": [
    "/assets/*",
    "/images/*",
    "/*.html",
    "/*.css",
    "/*.js",
    "/*.json",
    "/*.ico",
    "/*.png",
    "/*.jpg",
    "/*.jpeg",
    "/*.gif",
    "/*.webp",
    "/*.svg",
    "/*.woff",
    "/*.woff2",
    "/*.ttf",
    "/*.eot",
    "/*.otf",
    "/*.webmanifest",
    "/*.xml",
    "/*.txt",
    "/favicon.ico",
    "/robots.txt",
    "/sitemap.xml",
    "/manifest.json",
    "/sw.js",
    "/offline.html"
  ]
}
