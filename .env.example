# MIHAS Application System - Environment Variables Template
# Copy to .env.local and fill in your values
# Last updated: February 1, 2026
# Database: Neon Postgres | Storage: R2 (S3-Compatible) | Auth: Custom JWT

# ===========================================
# REQUIRED - Database (Neon Postgres)
# ===========================================
# Get connection string from: Neon Dashboard > Connection Details
DATABASE_URL=postgresql://[user]:[password]@[host]/[database]?sslmode=require

# ===========================================
# REQUIRED - File Storage (R2)
# ===========================================
# Get from: your storage provider R2 dashboard
R2_ACCOUNT_ID=[your-r2-account-id]
R2_ACCESS_KEY_ID=[your-r2-access-key-id]
R2_SECRET_ACCESS_KEY=[your-r2-secret-access-key]
R2_BUCKET_NAME=mihasapplication
R2_ENDPOINT=https://[r2-endpoint-host]
R2_PUBLIC_URL=https://[r2-public-host]/mihasapplication

# ===========================================
# REQUIRED - Security (Arcjet)
# ===========================================
# Get from: https://app.arcjet.com/dashboard
ARCJET_KEY=ajkey_[your-arcjet-key]

# ===========================================
# REQUIRED - JWT Authentication
# ===========================================
# Generate with: openssl rand -base64 48
JWT_SECRET=[your-jwt-secret-min-32-chars]
JWT_REFRESH_SECRET=[your-refresh-secret-min-32-chars]

# ===========================================
# REQUIRED - Application URLs
# ===========================================
# Production: https://apply.mihas.edu.zm
# Development: http://localhost:5173
VITE_API_BASE_URL=https://apply.mihas.edu.zm
VITE_APP_BASE_URL=https://apply.mihas.edu.zm

# ===========================================
# REQUIRED - Email Configuration (Resend)
# ===========================================
# Get API key from: https://resend.com/api-keys
RESEND_API_KEY=[your-resend-api-key]
EMAIL_FROM=admissions@mihas.edu.zm
RESEND_FROM_EMAIL=MIHAS Admissions <admissions@mihas.edu.zm>
APPLICATION_ADMIN_EMAILS=admissions@mihas.edu.zm

# ===========================================
# OPTIONAL - SMTP Fallback
# ===========================================
SMTP_HOST=smtp.zoho.com
SMTP_PORT=465
SMTP_USERNAME=[your-smtp-username]
SMTP_PASSWORD=[your-smtp-password]
SMTP_SECURE=true

# ===========================================
# Rate Limiting (defaults shown)
# ===========================================
RATE_LIMIT_DEFAULT_MAX_ATTEMPTS=60
RATE_LIMIT_AUTH_MAX_ATTEMPTS=10

# ===========================================
# Session & Security
# ===========================================
SESSION_TIMEOUT_MINUTES=30

# ===========================================
# File Upload
# ===========================================
MAX_FILE_SIZE_MB=10
ALLOWED_FILE_TYPES=image/*,.pdf,.doc,.docx

# ===========================================
# Application Metadata
# ===========================================
VITE_NODE_ENV=production
VITE_APP_VERSION=1.0.0

# ===========================================
# Push Notifications (VAPID)
# ===========================================
# Generate keys with: npx web-push generate-vapid-keys
VITE_VAPID_PUBLIC_KEY=[your-vapid-public-key]
VAPID_PUBLIC_KEY=[your-vapid-public-key]
VAPID_PRIVATE_KEY=[your-vapid-private-key]
VAPID_SUBJECT=mailto:admissions@mihas.edu.zm
