# MIHAS Application System - Environment Variables Template
# Copy to .env.local and fill in your values
# Last updated: April 2, 2026
# Database: Neon Postgres | Storage: R2 (S3-Compatible) | Auth: Custom JWT
#
# NOTE: Backend-only variables are documented in backend/.env.example.
# This file covers shared and frontend (VITE_) variables.

# ===========================================
# BACKEND - Database (Neon Postgres)
# ===========================================
# Get connection string from: Neon Dashboard > Connection Details
DATABASE_URL=postgresql://[user]:[password]@[host]/[database]?sslmode=require

# ===========================================
# BACKEND - File Storage (R2)
# ===========================================
# Get from: your storage provider R2 dashboard
R2_ACCOUNT_ID=[your-r2-account-id]
R2_ACCESS_KEY_ID=[your-r2-access-key-id]
R2_SECRET_ACCESS_KEY=[your-r2-secret-access-key]
R2_BUCKET_NAME=***REMOVED***
R2_ENDPOINT=https://[r2-endpoint-host]
R2_PUBLIC_URL=https://[r2-public-host]/***REMOVED***

# ===========================================
# BACKEND - JWT Authentication
# ===========================================
# Generate with: openssl rand -base64 48
JWT_SECRET=[your-jwt-secret-min-32-chars]
JWT_REFRESH_SECRET=[your-refresh-secret-min-32-chars]

# ===========================================
# FRONTEND (VITE_) - Application URLs
# ===========================================
# Production: ***REMOVED***
# Development: http://localhost:5173
VITE_API_BASE_URL=***REMOVED***
VITE_APP_BASE_URL=***REMOVED***

# ===========================================
# BACKEND - Email Configuration (Resend)
# ===========================================
# Get API key from: https://resend.com/api-keys
RESEND_API_KEY=[your-resend-api-key]
EMAIL_FROM=***REMOVED***
RESEND_FROM_EMAIL=MIHAS Admissions <***REMOVED***>
APPLICATION_ADMIN_EMAILS=***REMOVED***

# ===========================================
# OPTIONAL - SMTP Fallback (Zoho)
# ===========================================
ZOHO_SMTP_HOST=smtp.zoho.com
ZOHO_SMTP_PORT=465
ZOHO_SMTP_USERNAME=[your-smtp-username]
ZOHO_SMTP_PASSWORD=[your-smtp-password]

# ===========================================
# BACKEND - Rate Limiting (defaults shown)
# ===========================================
RATE_LIMIT_DEFAULT_MAX_ATTEMPTS=60
RATE_LIMIT_AUTH_MAX_ATTEMPTS=10

# ===========================================
# BACKEND - Session & Security
# ===========================================
SESSION_TIMEOUT_MINUTES=30

# ===========================================
# BACKEND - File Upload
# ===========================================
MAX_FILE_SIZE_MB=10
ALLOWED_FILE_TYPES=image/*,.pdf,.doc,.docx

# ===========================================
# FRONTEND (VITE_) - Application Metadata
# ===========================================
VITE_APP_VERSION=1.0.0
VITE_ERROR_REPORT_ENABLED=true

# ===========================================
# FRONTEND (VITE_) - Lenco Payment Widget
# ===========================================
# Widget script URL loaded by useLencoWidget hook.
# Production: https://pay.lenco.co/js/v1/inline.js
# Sandbox:    https://pay.sandbox.lenco.co/js/v1/inline.js
VITE_LENCO_WIDGET_URL=https://pay.lenco.co/js/v1/inline.js
# Frontend dev bypass: renders "Simulate Payment (Dev)" button in PaymentStep.
# Only active when import.meta.env.DEV is true (Vite dev server).
# MUST be false or unset in production builds.
VITE_PAYMENT_DEV_BYPASS=false
# Backend dev bypass: enables POST /api/v1/payments/dev-bypass/ endpoint.
# Creates a simulated payment record without real Lenco transaction.
# Only works when DEBUG=true. MUST be false or unset in production.
PAYMENT_DEV_BYPASS=false

# ===========================================
# STAGEHAND - AI Browser Automation (Local)
# ===========================================
# Stagehand uses a local Chromium instance (no Browserbase account needed).
# It requires an LLM API key for AI-driven page interaction.
# Supported: OpenAI (OPENAI_API_KEY) or Anthropic (ANTHROPIC_API_KEY)
OPENAI_API_KEY=[your-openai-api-key]
