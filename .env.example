# MIHAS Application System - Environment Variables Template
# Copy this file to .env.local and fill in your actual values

# Supabase Configuration
VITE_SUPABASE_URL=<your-supabase-project-url>
VITE_SUPABASE_ANON_KEY=<your-supabase-anon-key>

# Application URLs
VITE_API_BASE_URL=<your-api-base-url>
VITE_APP_BASE_URL=<your-app-base-url>

# Security Configuration
VITE_TURNSTILE_SITE_KEY=<your-turnstile-site-key>
TURNSTILE_SECRET_KEY=<your-turnstile-secret-key>
TEST_TOKEN=<your-test-token-for-development>

# Analytics (Optional)
VITE_ANALYTICS_BASE_URL=<your-analytics-url>
VITE_ANALYTICS_SITE_ID=<your-analytics-site-id>
VITE_ANALYTICS_SHARE_TOKEN=<your-analytics-token>
MIHAS_USE_MOCK_DATA=true

# Feature Flags
VITE_ENABLE_OCR=true
VITE_ENABLE_SMART_MATCHING=true
VITE_ENABLE_PERFORMANCE_MONITORING=true
VITE_ENABLE_DRAFT_MANAGEMENT=true

# Performance Configuration
VITE_AUTO_SAVE_INTERVAL=30000
VITE_API_CACHE_TTL=300000
VITE_DEV_SERVER_PORT=5173

# Storage Keys (Optional - will use defaults if not provided)
VITE_ADMIN_FILTERS_STORAGE_KEY=admin_applications_filters
VITE_API_CACHE_STORAGE_KEY=mihas-api-cache

# Email Configuration (Server-side)
EMAIL_PROVIDER=resend
EMAIL_FROM_ADDRESS=<your-from-email>
RESEND_API_KEY=<your-resend-api-key>
RESEND_FROM_EMAIL=<your-resend-from-email>
SENDGRID_API_KEY=<your-sendgrid-api-key>
SENDGRID_FROM_EMAIL=<your-sendgrid-from-email>
DEFAULT_FROM_EMAIL=<fallback-from-email>

# Twilio Configuration (Optional)
TWILIO_ACCOUNT_SID=<your-twilio-account-sid>
TWILIO_AUTH_TOKEN=<your-twilio-auth-token>
TWILIO_SMS_FROM=<your-twilio-sms-number>
TWILIO_SMS_MESSAGING_SERVICE_SID=<your-twilio-messaging-service-sid>
TWILIO_WHATSAPP_FROM=<your-twilio-whatsapp-number>

# AWS Configuration (for autoscaling)
AWS_ACCESS_KEY_ID=<your-aws-access-key>
AWS_SECRET_ACCESS_KEY=<your-aws-secret-key>
AWS_REGION=<your-aws-region>
SCALING_METRICS_QUEUE_URL=<your-sqs-queue-url>
NOTIFICATIONS_QUEUE_URL=<your-notifications-queue-url>

# CDN Configuration (for CloudFront deployment)
CDN_BUCKET_NAME=<your-s3-bucket-name>
CDN_DISTRIBUTION_ID=<your-cloudfront-distribution-id>
CDN_INVALIDATION_PATHS=/*
CDN_DEFAULT_CACHE_CONTROL=public,max-age=31536000,immutable
CDN_HTML_CACHE_CONTROL=public,max-age=300,must-revalidate
PUBLISH_TO_CDN=true