# MIHAS Application System - Environment Variables Template
# Copy to .env.local and fill in your values
# Last updated: January 30, 2026

# ===========================================
# REQUIRED - Supabase Configuration
# ===========================================
# Get these from: Supabase Dashboard > Settings > API
VITE_SUPABASE_URL=https://[project-ref].supabase.co
VITE_SUPABASE_ANON_KEY=[your-anon-key]
SUPABASE_URL=https://[project-ref].supabase.co
SUPABASE_SERVICE_ROLE_KEY=[your-service-role-key]

# ===========================================
# REQUIRED - Application URLs
# ===========================================
# Production: https://apply.mihas.edu.zm
# Development: http://localhost:5173
VITE_API_BASE_URL=https://apply.mihas.edu.zm
VITE_APP_BASE_URL=https://apply.mihas.edu.zm

# ===========================================
# REQUIRED - Email Configuration (Resend)
# ===========================================
# Get API key from: https://resend.com/api-keys
RESEND_API_KEY=[your-resend-api-key]
EMAIL_FROM=admissions@mihas.edu.zm

# ===========================================
# OPTIONAL - SMTP Fallback
# ===========================================
SMTP_HOST=smtp.zoho.com
SMTP_PORT=465
SMTP_USERNAME=[your-smtp-username]
SMTP_PASSWORD=[your-smtp-password]
SMTP_SECURE=true

# ===========================================
# Rate Limiting (defaults shown)
# ===========================================
RATE_LIMIT_DEFAULT_MAX_ATTEMPTS=60
RATE_LIMIT_AUTH_MAX_ATTEMPTS=10

# ===========================================
# Session & Security
# ===========================================
SESSION_TIMEOUT_MINUTES=30

# ===========================================
# File Upload
# ===========================================
MAX_FILE_SIZE_MB=10
ALLOWED_FILE_TYPES=image/*,.pdf,.doc,.docx

# ===========================================
# Application Metadata
# ===========================================
VITE_NODE_ENV=production
VITE_APP_VERSION=1.0.0
