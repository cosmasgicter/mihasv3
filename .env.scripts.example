# ============================================================
# WARNING: Never commit real credentials to the repository.
# Copy this file to .env.scripts and fill in actual values.
# .env.scripts is gitignored and must never be checked in.
# ============================================================

# Required by: scripts/test-user-flow.ts
TEST_STUDENT_EMAIL=your-test-student@example.com
TEST_ADMIN_EMAIL=your-test-admin@example.com
TEST_PASSWORD=your-test-password

# Required by: scripts/measure-login-performance.js, scripts/verify-phase2-performance.js
TEST_EMAIL=your-test-email@example.com
# TEST_PASSWORD is shared with the entry above

# Required by: scripts/set-passwords-and-notify.ts
# TEST_PASSWORD is shared with the entry above
# DATABASE_URL and RESEND_API_KEY should be set in your main .env file

# Optional
BASE_URL=https://apply.beanola.com
APP_URL=https://apply.beanola.com
API_URL=https://api.beanola.com

# Required by: scripts/e2e-production-admissions.sh safe-write
# Use active catalog names/codes from /api/v1/catalog/programs/ and intakes.
E2E_PROGRAM=your-program-name-or-code
E2E_INTAKE=your-intake-name
E2E_INSTITUTION=your-institution-name
E2E_SUBJECT_IDS=uuid-1,uuid-2,uuid-3,uuid-4,uuid-5
E2E_GRADE=3
