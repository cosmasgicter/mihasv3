{
  "name": "mihas-monorepo",
  "private": true,
  "workspaces": ["apps/*", "shared"],
  "overrides": {
    "@hono/node-server": "2.0.1",
    "dompurify": "3.4.2",
    "hono": "4.12.18",
    "ip-address": "10.2.0",
    "minimatch": "10.2.5",
    "postcss": "8.5.14",
    "vite": "6.4.2"
  },
  "scripts": {
    "dev:admissions": "cd apps/admissions && bun run dev",
    "dev:jobs-ops": "cd apps/jobs-ops && bun run dev",
    "build:admissions": "cd apps/admissions && bun run build",
    "build:jobs-ops": "cd apps/jobs-ops && bun run build",
    "test:admissions": "cd apps/admissions && bun run test",
    "lint:admissions": "cd apps/admissions && bun run lint",
    "lint:jobs-ops": "cd apps/jobs-ops && bun run lint",
    "type-check:jobs-ops": "cd apps/jobs-ops && bun run type-check"
  }
}
