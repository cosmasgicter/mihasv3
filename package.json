{
  "name": "mihas-application-system-v2",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "packageManager": "bun@1.2.5",
  "scripts": {
    "dev": "bunx --bun vite",
    "dev:network": "bunx --bun vite --host 0.0.0.0",
    "dev:prod": "bun run build && bunx --bun vite preview",
    "dev:api": "bun run local-server.js",
    "dev:full": "bunx concurrently \"bun run dev:api\" \"bun run dev\"",
    "build": "bun run type-check && bunx --bun vite build",
    "build:prod": "bun run build",
    "build:analyze": "bun run type-check && bunx --bun vite build --mode production && bunx vite-bundle-analyzer dist/stats.html",
    "preview": "bunx --bun vite preview",
    "type-check": "tsc --noEmit",
    "lint": "bun run check:mojibake && bun run check:no-supabase-runtime && bunx eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "test": "bun run check:mojibake && bunx vitest run",
    "test:watch": "bunx vitest",
    "validate:tailwind": "./scripts/validate-tailwind-classes.sh",
    "storage:setup": "bun run setup-storage.js",
    "security-audit": "bun run security-audit.js",
    "session:setup": "bun run setup-session-management.js",
    "microservices:setup": "bun run setup-microservices.js",
    "verify:notifications": "bun run verify-notification-setup.js",
    "verify:api-layout": "bun run verify-api-layout.js",
    "audit": "bun run scripts/audit/runFullAudit.ts --full",
    "audit:contract": "bun run scripts/audit/runFullAudit.ts --contract",
    "audit:page": "bun run scripts/audit/runFullAudit.ts --page",
    "audit:loader": "bun run scripts/audit/runFullAudit.ts --loader",
    "audit:auth": "bun run scripts/audit/runFullAudit.ts --auth",
    "audit:sse": "bun run scripts/audit/runFullAudit.ts --sse",
    "audit:notification": "bun run scripts/audit/runFullAudit.ts --notification",
    "audit:performance": "bun run scripts/audit/runFullAudit.ts --performance",
    "audit:deadcode": "bun run scripts/audit/runFullAudit.ts --deadcode",
    "audit:summary": "bun run scripts/audit/generateSummary.ts",
    "check:mojibake": "node scripts/check-mojibake.js",
    "check:no-supabase-runtime": "./scripts/ci/check-no-supabase-runtime.sh"
  },
  "dependencies": {
    "@arcjet/decorate": "1.0.0",
    "@arcjet/node": "1.0.0",
    "@aws-sdk/client-sqs": "^3.895.0",
    "@hookform/resolvers": "5.2.2",
    "@neondatabase/serverless": "1.0.2",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@radix-ui/react-progress": "^1.1.7",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.15",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tailwindcss/forms": "^0.5.10",
    "@tanstack/react-query": "^5.62.7",
    "@tanstack/react-virtual": "^3.13.12",
    "@tsparticles/react": "^3.0.0",
    "@tsparticles/slim": "^3.9.1",
    "@types/bcryptjs": "3.0.0",
    "@types/dompurify": "^3.2.0",
    "@types/pg": "8.16.0",
    "@types/react-window": "^1.8.8",
    "@vercel/analytics": "1.6.1",
    "@vercel/speed-insights": "1.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "bcryptjs": "3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "dompurify": "^3.2.3",
    "dotenv": "^16.6.1",
    "exceljs": "^4.4.0",
    "express": "^4.21.2",
    "form-data": "^4.0.1",
    "jose": "6.1.3",
    "jspdf": "^3.0.3",
    "jspdf-autotable": "^5.0.2",
    "lucide-react": "^0.468.0",
    "node-fetch": "^3.3.2",
    "pdf-lib": "^1.17.1",
    "pg": "8.18.0",
    "postcss": "^8.5.1",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-dropzone": "^14.3.8",
    "react-hook-form": "^7.55.0",
    "react-intersection-observer": "^9.14.0",
    "react-router-dom": "^6.29.0",
    "react-window": "^1.8.10",
    "recharts": "^3.2.1",
    "resend": "6.9.1",
    "tailwind-merge": "^2.5.5",
    "tailwindcss": "^3.4.17",
    "tailwindcss-animate": "^1.0.7",
    "tesseract.js": "^5.1.1",
    "typescript": "^5.9.3",
    "vite": "^6.0.3",
    "vite-plugin-pwa": "^0.21.1",
    "web-push": "^3.6.7",
    "web-vitals": "^4.2.4",
    "xlsx": "^0.18.5",
    "zod": "4.3.6",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@types/node": "^22.18.12",
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "@types/web-push": "^3.6.4",
    "@typescript-eslint/eslint-plugin": "^8.18.1",
    "@typescript-eslint/parser": "^8.18.1",
    "@vercel/node": "^5.5.28",
    "@vitest/coverage-v8": "4.0.18",
    "baseline-browser-mapping": "^2.9.15",
    "concurrently": "^9.1.0",
    "critters": "^0.0.23",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "fast-check": "4.5.3",
    "globals": "^15.12.0",
    "jsdom": "27.4.0",
    "shadcn": "^3.6.3",
    "sharp": "^0.34.4",
    "terser": "^5.37.0",
    "typescript-eslint": "^8.18.1",
    "vitest": "4.0.18"
  }
}
