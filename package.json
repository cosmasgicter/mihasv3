{
  "name": "mihas-application-system-v2",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": ">=24.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "dev": "vite --config vite.config.local.ts",
    "dev:network": "vite --config vite.config.local.ts --host 0.0.0.0",
    "dev:prod": "vite build --config vite.config.production.ts && vite preview",
    "dev:api": "node local-server.js",
    "dev:full": "concurrently \"npm run dev:api\" \"npm run dev\"",
    "dev:netlify": "netlify dev",
    "build": "tsc -p tsconfig.build.json && vite build --config vite.config.production.ts",
    "build:prod": "tsc -p tsconfig.build.json && vite build --config vite.config.production.ts --mode production",
    "build:analyze": "tsc -p tsconfig.build.json && vite build --mode production && npx vite-bundle-analyzer dist/stats.html",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "deploy": "netlify deploy",
    "deploy:prod": "netlify deploy --prod",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:debug": "playwright test --debug",
    "test:install": "playwright install",
    "test:auth": "playwright test tests/auth.spec.ts",
    "test:wizard": "playwright test tests/application-wizard.spec.ts",
    "test:wizard:regression": "playwright test tests/e2e/wizard-regression.spec.ts",
    "test:enhanced": "playwright test tests/enhanced-features.spec.ts",
    "test:api": "playwright test tests/integration/api-services.spec.ts",
    "test:wizard:navigation": "playwright test tests/integration/wizard-navigation.test.js",
    "test:unit": "vitest",
    "test:unit:watch": "vitest --watch",
    "test:unit:coverage": "vitest --coverage",
    "test:api-functions": "vitest tests/api",
    "type-check": "tsc -p tsconfig.build.json --noEmit",
    "storage:setup": "node setup-storage.js",
    "storage:test": "node testing/test-storage.js",
    "security-audit": "node security-audit.js",
    "session:setup": "node setup-session-management.js",
    "session:test": "node test-session-management.js",
    "microservices:setup": "node setup-microservices.js",
    "test:services": "node test-production-services.js",
    "test:services:curl": "./test-services-curl.sh",
    "test:notifications": "playwright test tests/integration/test-notification-integration.js",
    "verify:notifications": "node verify-notification-setup.js",
    "test:notification-system": "node test-notification-system.js",
    "verify:api-layout": "node verify-api-layout.js"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.10.0",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@radix-ui/react-progress": "^1.1.7",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.15",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@supabase/supabase-js": "^2.48.1",
    "@tailwindcss/forms": "^0.5.10",
    "@tanstack/react-query": "^5.62.7",
    "@types/dompurify": "^3.2.0",
    "@types/react-window": "^1.8.8",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "clsx": "^2.1.1",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "dompurify": "^3.2.3",
    "dotenv": "^16.4.7",
    "exceljs": "^4.4.0",
    "express": "^4.21.2",
    "form-data": "^4.0.1",
    "framer-motion": "^11.15.0",
    "jspdf": "^3.0.3",
    "jspdf-autotable": "^5.0.2",
    "lucide-react": "^0.468.0",
    "node-fetch": "^3.3.2",
    "pdf-lib": "^1.17.1",
    "postcss": "^8.5.1",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-dropzone": "^14.3.5",
    "react-hook-form": "^7.54.0",
    "react-intersection-observer": "^9.14.0",
    "react-router-dom": "^6.29.0",
    "react-window": "^1.8.10",
    "recharts": "^3.2.1",
    "tailwind-merge": "^2.5.5",
    "tailwindcss": "^3.4.17",
    "tailwindcss-animate": "^1.0.7",
    "tesseract.js": "^5.1.1",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "vite-plugin-pwa": "^0.21.1",
    "web-push": "^3.6.7",
    "web-vitals": "^4.2.4",
    "xlsx": "^0.18.5",
    "zod": "^3.24.1",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.1",
    "@testing-library/react": "^16.1.0",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "@types/web-push": "^3.6.4",
    "@typescript-eslint/eslint-plugin": "^8.18.1",
    "@typescript-eslint/parser": "^8.18.1",
    "concurrently": "^9.1.0",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "jsdom": "^25.0.1",
    "terser": "^5.37.0",
    "typescript-eslint": "^8.18.1",
    "vitest": "^3.2.4"
  }
}
