# MIHAS Application System - Production Environment Variables
# Updated: April 16, 2026
#
# ARCHITECTURE:
#   Frontend (Vercel): Only needs VITE_* vars — baked into JS at build time
#   Backend (Koyeb):   Needs everything else — Django reads at runtime
#
# Keep real values in your deployment platform secret manager.

# ============================================
# VERCEL (Frontend) — set in Vercel dashboard
# ============================================
VITE_API_BASE_URL=https://api.mihas.edu.zm
VITE_APP_BASE_URL=https://apply.mihas.edu.zm
VITE_APP_VERSION=1.0.0
VITE_LENCO_WIDGET_URL=https://pay.lenco.co/js/v1/inline.js
VITE_ERROR_REPORT_ENABLED=true

# ============================================
# KOYEB (Backend) — set in Koyeb dashboard
# ============================================

# --- Django Core ---
DJANGO_SETTINGS_MODULE=config.settings.prod
SECRET_KEY=[set-in-hosting-platform]
DEBUG=false
ALLOWED_HOSTS=api.mihas.edu.zm

# --- Database (Neon Postgres) ---
DATABASE_URL=postgresql://[user]:[password]@[host]/[database]?sslmode=require

# --- Redis (Upstash) ---
REDIS_URL=rediss://[set-in-hosting-platform]
CELERY_BROKER_URL=rediss://[set-in-hosting-platform]

# --- JWT ---
JWT_SIGNING_KEY=[set-in-hosting-platform]

# --- CORS ---
CORS_ALLOWED_ORIGINS=https://apply.mihas.edu.zm
CSRF_TRUSTED_ORIGINS=https://apply.mihas.edu.zm

# --- Email (Resend) ---
RESEND_API_KEY=[set-in-hosting-platform]
EMAIL_FROM=admissions@mihas.edu.zm
ERROR_ALERT_EMAIL=admin@mihas.edu.zm

# --- Lenco Payment Gateway (LIVE) ---
# Server-side secret for Lenco API calls (initiate, verify, webhook validation).
# Get from Lenco dashboard > API Keys > Live Secret Key.
LENCO_API_SECRET_KEY=[set-in-hosting-platform]
# Live API base URL — do NOT use sandbox in production.
LENCO_API_BASE_URL=https://api.lenco.co/access/v2/
# Client-side public key returned in /payments/initiate/ response for the widget.
# Get from Lenco dashboard > API Keys > Live Public Key.
LENCO_PUBLIC_KEY=[set-in-hosting-platform]
# PAYMENT_DEV_BYPASS: MUST be false (or unset) in production.
# The dev bypass endpoint (POST /api/v1/payments/dev-bypass/) is also gated
# behind DEBUG=true, so it cannot activate in production even if set to true.
# PAYMENT_DEV_BYPASS=false

# --- S3/R2 Storage ---
S3_ENDPOINT_URL=https://[account-id].r2.cloudflarestorage.com
S3_BUCKET=mihasapplication
S3_ACCESS_KEY=[set-in-hosting-platform]
S3_SECRET_KEY=[set-in-hosting-platform]

# --- Runtime ---
HEALTH_CHECK_URL=https://api.mihas.edu.zm/health/ready/
PORT=8000
WEB_CONCURRENCY=3
READ_ONLY_MODE=false
