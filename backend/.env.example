# MIHAS Django API - production environment example
# Copy into your secret manager or Koyeb environment variable settings.

# Required
DJANGO_SETTINGS_MODULE=config.settings.prod
SECRET_KEY=replace-with-a-long-random-secret
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DBNAME?sslmode=require
POSTGRES_DB=mihas_local
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
REDIS_URL=rediss://default:password@your-redis-host:6379
JWT_SIGNING_KEY=replace-with-a-separate-long-random-jwt-signing-key
ALLOWED_HOSTS=api.mihas.edu.zm
CORS_ALLOWED_ORIGINS=https://apply.mihas.edu.zm
CORS_ALLOWED_ORIGIN_REGEXES=^https://([A-Za-z0-9-]+\.)*beanola\.com$,^https://([A-Za-z0-9-]+\.)*mihas\.edu\.zm$,^https://([A-Za-z0-9-]+\.)*katc\.edu\.zm$
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxx
S3_ENDPOINT_URL=https://<account-id>.r2.cloudflarestorage.com
S3_BUCKET=mihasapplication
S3_ACCESS_KEY=replace-with-r2-access-key
S3_SECRET_KEY=replace-with-r2-secret-key

# Optional but recommended
EMAIL_FROM=admissions@mihas.edu.zm
# Recipient for error alert emails (uptime, payment failures, SLA breaches)
ERROR_ALERT_EMAIL=admin@mihas.edu.zm
# GlitchTip / Sentry-compatible DSN for backend error tracking.
# Get from: GlitchTip project settings > Client Keys (DSN)
# Points to https://app.glitchtip.com (or self-hosted instance)
# Security endpoint for CSP reporting: https://app.glitchtip.com/api/{project_id}/security/?glitchtip_key={key}
GLITCHTIP_DSN=
CELERY_BROKER_URL=rediss://default:password@your-redis-host:6379
AUDIT_LOG_ENCRYPTION_KEY=replace-with-base64-fernet-key
PORT=8000
WEB_CONCURRENCY=3
READ_ONLY_MODE=false
# Internal health check URL for the check_uptime_task Celery periodic task
HEALTH_CHECK_URL=https://api.mihas.edu.zm/health/ready/
LOG_LEVEL=INFO
APP_VERSION=dev
CSRF_TRUSTED_ORIGINS=https://apply.mihas.edu.zm

# Web push
VAPID_PUBLIC_KEY=replace-with-vapid-public-key
VAPID_PRIVATE_KEY=replace-with-vapid-private-key
VAPID_SUBJECT=mailto:admissions@mihas.edu.zm

# AI (Vercel AI Gateway — routes to Gemini, DeepSeek, etc.)
AI_GATEWAY_API_KEY=replace-with-vercel-ai-gateway-key
AI_GATEWAY_BASE_URL=https://ai-gateway.vercel.sh/v1

# Jobs Ops integrations
TELEGRAM_BOT_TOKEN=replace-with-telegram-bot-token
TELEGRAM_WEBHOOK_SECRET=replace-with-telegram-webhook-secret
ZOHO_SMTP_HOST=smtp.zoho.com
ZOHO_SMTP_PORT=465
ZOHO_SMTP_USERNAME=replace-with-zoho-smtp-username
ZOHO_SMTP_PASSWORD=replace-with-zoho-smtp-password
ZOHO_IMAP_HOST=imap.zoho.com
ZOHO_IMAP_PORT=993
ZOHO_IMAP_USERNAME=replace-with-zoho-imap-username
ZOHO_IMAP_PASSWORD=replace-with-zoho-imap-password
ZOHO_FROM_EMAIL=replace-with-zoho-from-email
PLAYWRIGHT_SERVICE_URL=https://playwright-worker-placeholder.example.com
PLAYWRIGHT_API_TOKEN=replace-with-playwright-api-token
OCR_PROVIDER=tesseract
OCR_API_KEY=replace-with-ocr-api-key
JOBS_OPS_FRONTEND_URL=https://jobs-ops-placeholder.example.com
PUBLIC_API_URL=https://api.mihas.edu.zm

# Lenco payment gateway
# ---
# LENCO_API_SECRET_KEY: Server-side secret for Lenco API calls (initiate, verify).
#   Get from Lenco dashboard > API Keys. Sandbox and live keys are different.
# LENCO_API_BASE_URL: Lenco API base URL.
#   Sandbox: https://sandbox.lenco.co/access/v2/
#   Live:    https://api.lenco.co/access/v2/
# LENCO_PUBLIC_KEY: Client-side public key embedded in the payment widget config.
#   Get from Lenco dashboard > API Keys > Public Key.
# PAYMENT_DEV_BYPASS: Enables POST /api/v1/payments/dev-bypass/ endpoint.
#   Only works when DEBUG=true. Creates a simulated payment record and sets
#   application payment_status to 'verified' without real Lenco transaction.
#   MUST be false (or unset) in production. Set true only in local dev.
LENCO_API_SECRET_KEY=replace-with-lenco-api-secret-key
LENCO_API_BASE_URL=https://sandbox.lenco.co/access/v2/
LENCO_PUBLIC_KEY=replace-with-lenco-public-key
PAYMENT_DEV_BYPASS=false
