{
  "name": "mihas-application-system-v2",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "packageManager": "bun@1.2.5",
  "scripts": {
    "dev": "node ./scripts/prepare-ocr-assets.mjs && bun x --bun vite",
    "dev:network": "node ./scripts/prepare-ocr-assets.mjs && bun x --bun vite --host 0.0.0.0",
    "dev:prod": "bun run build && bun x --bun vite preview",
    "build": "node ./scripts/prepare-ocr-assets.mjs && tsc -p tsconfig.build.json --noEmit && ./node_modules/.bin/vite build && bun scripts/check-html-csp.ts",
    "build:prod": "bun run build",
    "build:analyze": "node ./scripts/prepare-ocr-assets.mjs && tsc -p tsconfig.build.json --noEmit && ./node_modules/.bin/vite build --mode production && bun x vite-bundle-analyzer dist/stats.html",
    "preview": "bun x --bun vite preview",
    "type-check": "tsc -p tsconfig.build.json --noEmit",
    "type-check:full": "tsc --noEmit",
    "lint": "bun x eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "test": "bun x vitest run",
    "test:watch": "bun x vitest",
    "validate:tailwind": "./scripts/validate-tailwind-classes.sh",
    "check:imports": "bun scripts/check-dynamic-imports.ts",
    "check:entry": "bun scripts/check-entry-chunk.ts",
    "check:html": "bun scripts/check-html-csp.ts",
    "check:all": "bun run check:imports && bun run check:entry && bun run check:html",
    "security-audit": "bun run security-audit.js"
  },
  "dependencies": {
    "@hookform/resolvers": "5.2.2",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.15",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@react-pdf/renderer": "^4.5.1",
    "@sentry/react": "^10.52.0",
    "@tailwindcss/forms": "^0.5.11",
    "@tanstack/react-query": "^5.100.9",
    "@tanstack/react-virtual": "^3.13.24",
    "@vercel/analytics": "1.6.1",
    "@vercel/speed-insights": "1.3.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dompurify": "3.4.2",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^0.468.0",
    "pdf-lib": "^1.17.1",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-dropzone": "^14.4.1",
    "react-hook-form": "^7.75.0",
    "react-intersection-observer": "^9.16.0",
    "react-router-dom": "^6.30.3",
    "recharts": "^3.8.1",
    "tailwind-merge": "^2.6.1",
    "tesseract.js": "7.0.0",
    "tesseract.js-core": "7.0.0",
    "zod": "4.3.6",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.11.1",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@fontsource/playfair-display": "^5.2.8",
    "@fontsource/source-sans-3": "^5.2.9",
    "@playwright/test": "1.58.2",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.19.18",
    "@types/qrcode": "1.5.6",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@typescript-eslint/eslint-plugin": "^8.59.2",
    "@typescript-eslint/parser": "^8.59.2",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-v8": "4.0.18",
    "autoprefixer": "^10.5.0",
    "baseline-browser-mapping": "^2.10.29",
    "concurrently": "^9.2.1",
    "critters": "^0.0.23",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.26",
    "fast-check": "4.5.3",
    "fast-glob": "^3.3.3",
    "globals": "^15.15.0",
    "jsdom": "27.4.0",
    "postcss": "^8.5.14",
    "shadcn": "^3.8.5",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.19",
    "tailwindcss-animate": "^1.0.7",
    "terser": "^5.47.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.2",
    "vite": "^6.4.2",
    "vitest": "4.0.18"
  }
}
