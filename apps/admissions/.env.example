# MIHAS Admissions Frontend — Environment Variables
# Copy to .env and fill in your values

# ===========================================
# API Base URL (Django backend)
# ===========================================
# Production (default when not set): https://api.mihas.edu.zm
# Local development against Django dev server:
VITE_API_BASE_URL=http://localhost:8000

# ===========================================
# Application URLs
# ===========================================
# Production: https://apply.mihas.edu.zm
# Local development:
VITE_APP_BASE_URL=http://localhost:5173

# ===========================================
# Application Metadata
# ===========================================
VITE_APP_VERSION=2.0.0
VITE_NODE_ENV=development

# ===========================================
# Push Notifications (VAPID)
# ===========================================
# Generate keys with: npx web-push generate-vapid-keys
VITE_VAPID_PUBLIC_KEY=[your-vapid-public-key]
