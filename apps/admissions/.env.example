# MIHAS Admissions frontend - environment variables
# Copy to .env.local for local work or set these in Vercel.

# API origin only. Do not append /api/v1 here; the client adds it.
# Required for production/Vercel builds.
# Local:
VITE_API_BASE_URL=http://localhost:8000
# Production:
# VITE_API_BASE_URL=***REMOVED***

# Frontend public URL. Production should stay on a mihas.edu.zm subdomain so
# the Django API's SameSite=Lax shared-cookie strategy keeps working.
# Required for production/Vercel builds.
# Local:
VITE_APP_BASE_URL=http://localhost:5173
# Production:
# VITE_APP_BASE_URL=***REMOVED***

# Canonical site URL used by SEO helpers.
# Required for production/Vercel builds.
# Local:
# VITE_SITE_URL=http://localhost:5173
# Production:
# VITE_SITE_URL=***REMOVED***

# Release identifier shown in the app and used for reload/version control.
# Required for production/Vercel builds. In Vercel, map this to a commit SHA
# or release id, for example: VITE_APP_VERSION=$VERCEL_GIT_COMMIT_SHA
VITE_APP_VERSION=dev

# Optional feature flags
VITE_ENABLE_AUTO_RELOAD=false
VITE_ENABLE_LOADER_TELEMETRY=false

# Error reporting — enables the frontend error reporter that POSTs to /api/v1/errors/report/
VITE_ERROR_REPORT_ENABLED=true

# Lenco Payment Gateway
# Public key for the Lenco inline widget. Swap for production key in Vercel.
VITE_LENCO_PUBLIC_KEY=pub-test-key-placeholder
# Widget script URL. Sandbox for development, production URL for go-live.
# Sandbox:
VITE_LENCO_WIDGET_URL=https://pay.sandbox.lenco.co/js/v1/inline.js
# Frontend dev bypass: renders "Simulate Payment (Dev)" button in PaymentStep
# that skips the Lenco widget and calls onPaymentStatusChange('successful').
# Only active when import.meta.env.DEV is true (Vite dev server).
# MUST be false or unset in production Vercel builds.
VITE_PAYMENT_DEV_BYPASS=false
# Production:
# VITE_LENCO_WIDGET_URL=https://pay.lenco.co/js/v1/inline.js
