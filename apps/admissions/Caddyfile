# MIHAS edge — Caddy serves the SPA (apply.) and proxies the API (api.).
# Auto-HTTPS via Let's Encrypt for both names (certs persist in the caddy-data
# volume). Both subdomains terminate here, so the existing two-origin frontend
# + `.mihas.edu.zm` SameSite=None cookies keep working unchanged.
#
# {$ADMIN_EMAIL} and the two host vars are supplied by the caddy container env.

{
	email {$ADMIN_EMAIL}
}

# --- Frontend: apply.mihas.edu.zm -------------------------------------------
{$APP_HOST} {
	root * /srv/www
	encode zstd gzip

	# Security + CSP headers — ported verbatim from apps/admissions/vercel.json.
	# Keep in sync with vercel.json until Vercel is fully retired.
	header {
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		Referrer-Policy "strict-origin-when-cross-origin"
		X-Permitted-Cross-Domain-Policies "none"
		Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=()"
		Content-Security-Policy "default-src 'self'; script-src 'self' 'wasm-unsafe-eval' blob: https://va.vercel-scripts.com https://pay.lenco.co https://pay.sandbox.lenco.co; worker-src 'self' blob:; child-src 'self' blob:; style-src 'self' 'unsafe-inline'; style-src-elem 'self' 'unsafe-inline'; img-src 'self' data: blob:; font-src 'self'; connect-src 'self' data: ***REMOVED*** https://pay.lenco.co https://pay.sandbox.lenco.co https://api.lenco.co https://api.sandbox.lenco.co https://app.glitchtip.com https://*.r2.cloudflarestorage.com; frame-src 'self' https://pay.lenco.co https://pay.sandbox.lenco.co; frame-ancestors 'none'; base-uri 'self'; form-action 'self'; upgrade-insecure-requests; report-uri https://app.glitchtip.com/api/22431/security/?glitchtip_key=8a2c416ba7464b6bb50a194b32b12832"
		-Server
	}

	# Hashed build assets — immutable, 1 year.
	@assets path /assets/*
	header @assets Cache-Control "public, max-age=31536000, immutable"

	# Content images — 1 day + SWR week.
	@images path /images/*
	header @images Cache-Control "public, max-age=86400, stale-while-revalidate=604800"

	# HTML/app shell — always revalidate so new deploys are picked up.
	@html {
		not path /assets/* /images/* /favicon.ico /robots.txt /sitemap.xml
	}
	header @html Cache-Control "no-cache, must-revalidate"

	# SPA fallback: serve index.html for client-routed paths (mirrors the
	# vercel.json rewrite that excludes static asset prefixes).
	try_files {path} /index.html
	file_server
}

# --- API: api.mihas.edu.zm --------------------------------------------------
# Reverse proxy to the Django/uvicorn container. Caddy terminates TLS and sets
# X-Forwarded-Proto=https, which the backend's SECURE_PROXY_SSL_HEADER trusts
# (so SECURE_SSL_REDIRECT does not loop). Caddy adds X-Forwarded-For/Host too.
{$API_HOST} {
	encode zstd gzip
	header -Server
	reverse_proxy web:8000
}
